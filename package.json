{
  "name": "muxx",
  "version": "0.1.0",
  "description": "Minimal tmux session automation CLI",
  "type": "module",
  "bin": {
    "muxx": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node --import tsx/esm src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "node --import tsx/esm --test src/core/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist"
  ]
}
