{
  "name": "@harshsandhu44/muxx",
  "version": "0.1.0",
  "description": "Minimal tmux session automation CLI",
  "type": "module",
  "bin": {
    "muxx": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node --import tsx/esm src/cli.ts",
    "build": "tsc && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "node --import tsx/esm --test src/core/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.0",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "picocolors": "^1.1.1"
  }
}
